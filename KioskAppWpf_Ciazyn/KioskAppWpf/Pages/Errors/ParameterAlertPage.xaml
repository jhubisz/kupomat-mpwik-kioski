<Page x:Class="KioskAppWpf.Pages.Errors.ParameterAlertPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KioskAppWpf.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="492" d:DesignWidth="792"
      Title="ErrorPage"
      Loaded="PageLoad"
      Unloaded="PageUnload">

    <Grid Background="#FF76CEF0" Margin="0,-1,0,1">
        <TextBlock Margin="0,198,0,270" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" Foreground="#FFD10C13" FontFamily="Lucida Console" FontSize="24"><Run Text="Przekroczono parametry zrzutu"/><Run Text="!"/></TextBlock>
        <TextBlock Margin="150,70,150,0" TextAlignment="Center" TextWrapping="Wrap" Text="Skontatkuj się z obsługą obiektu" Foreground="#FFD10C13" FontFamily="Lucida Console" FontSize="18" Height="100" VerticalAlignment="Center"/>
        <TextBlock Margin="150,120,150,0" Name="tbTakeRecipt" TextAlignment="Center" TextWrapping="Wrap" Text="Odbierz potwierdzenie przyjęcia dostawy" Visibility="Hidden" TextDecorations="Underline" Foreground="#FFD10C13" FontFamily="Lucida Console" FontSize="18" Height="100" VerticalAlignment="Center" FontWeight="Bold"/>
        <TextBlock Margin="150,120,150,0" Name="tbPrintingBlocked" TextAlignment="Center" TextWrapping="Wrap" Text="Drukowanie paragonu zablokowane" Visibility="Hidden" TextDecorations="Underline" Foreground="#FFD10C13" FontFamily="Lucida Console" FontSize="18" Height="100" VerticalAlignment="Center" FontWeight="Bold"/>
        <TextBlock Margin="0,130,0,0" TextAlignment="Center" Name="tbErrorCode" TextWrapping="Wrap" Text="Kod błędu err202: Przekroczono parametry zrzutu" VerticalAlignment="Center" Foreground="#FFD10C13" FontFamily="Lucida Console" FontSize="18"/>
    </Grid>
</Page>
