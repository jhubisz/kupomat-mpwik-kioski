<Application x:Class="KioskAppWpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:KioskAppWpf"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Style x:Key="TextMain" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Lucida Console"></Setter>
            <Setter Property="FontSize" Value="16"></Setter>
            <Setter Property="Foreground" Value="#FF0378A4"></Setter>
            <Setter Property="HorizontalAlignment" Value="Left"></Setter>
            <Setter Property="VerticalAlignment" Value="Top"></Setter>
            <Setter Property="TextWrapping" Value="Wrap"></Setter>
        </Style>
        <Style x:Key="TextMainSmall" TargetType="TextBlock" BasedOn="{StaticResource ResourceKey=TextMain}">
            <Setter Property="FontSize" Value="12"></Setter>
        </Style>
        <Style x:Key="TextMainGreen" TargetType="TextBlock" BasedOn="{StaticResource ResourceKey=TextMain}">
            <Setter Property="Foreground" Value="#FFFFB600"></Setter>
        </Style>
        <Style x:Key="TextMainBold" TargetType="TextBlock" BasedOn="{StaticResource ResourceKey=TextMain}">
            <Setter Property="FontWeight" Value="Bold"></Setter>
        </Style>
        <Style x:Key="TextMainUnderline" TargetType="TextBlock" BasedOn="{StaticResource ResourceKey=TextMain}">
            <Setter Property="TextDecorations" Value="Underline"></Setter>
            <Setter Property="FontWeight" Value="Bold"></Setter>
        </Style>
        <Style x:Key="TextPageHead" TargetType="TextBlock" BasedOn="{StaticResource ResourceKey=TextMain}">
            <Setter Property="FontSize" Value="20"></Setter>
            <Setter Property="TextAlignment" Value="Center"></Setter>
            <Setter Property="HorizontalAlignment" Value="Center"></Setter>
        </Style>

        <Style x:Key="TextErrorHead" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Lucida Console"></Setter>
            <Setter Property="FontSize" Value="24"></Setter>
            <Setter Property="Foreground" Value="#FFD10C13"></Setter>
            <Setter Property="TextAlignment" Value="Center"></Setter>
            <Setter Property="HorizontalAlignment" Value="Center"></Setter>
            <Setter Property="VerticalAlignment" Value="Center"></Setter>
            <Setter Property="TextWrapping" Value="Wrap"></Setter>
        </Style>
        <Style x:Key="TextError" TargetType="TextBlock" BasedOn="{StaticResource ResourceKey=TextErrorHead}">
            <Setter Property="FontSize" Value="18"></Setter>
        </Style>

        <Style x:Key="LabelForm" TargetType="Label">
            <Setter Property="FontFamily" Value="Lucida Console"></Setter>
            <Setter Property="FontSize" Value="18"></Setter>
            <Setter Property="Foreground" Value="#FF0378A4"></Setter>
            <Setter Property="HorizontalAlignment" Value="Left"></Setter>
            <Setter Property="VerticalAlignment" Value="Top"></Setter>
            <Setter Property="Height" Value="30"></Setter>
            <Setter Property="VerticalContentAlignment" Value="Center"></Setter>
        </Style>
        <Style x:Key="LabelButton" TargetType="Label">
            <Setter Property="FontFamily" Value="Lucida Console"></Setter>
            <Setter Property="FontSize" Value="18"></Setter>
            <Setter Property="Foreground" Value="#FF76CEF0"></Setter>
            <Setter Property="Background" Value="#FF0378A4"></Setter>
            <Setter Property="HorizontalAlignment" Value="Left"></Setter>
            <Setter Property="VerticalAlignment" Value="Top"></Setter>
            <Setter Property="VerticalContentAlignment" Value="Center"></Setter>
            <Setter Property="Height" Value="36"></Setter>
        </Style>
        <Style x:Key="TextBlockButton" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Lucida Console"></Setter>
            <Setter Property="FontSize" Value="36"></Setter>
            <Setter Property="FontWeight" Value="Bold"></Setter>
            <Setter Property="Foreground" Value="#FF76CEF0"></Setter>
            <Setter Property="Background" Value="#FF0378A4"></Setter>
            <Setter Property="HorizontalAlignment" Value="Left"></Setter>
            <Setter Property="VerticalAlignment" Value="Top"></Setter>
            <Setter Property="Height" Value="36"></Setter>
            <Setter Property="TextAlignment" Value="Center"></Setter>
        </Style>
    </Application.Resources>
</Application>
