<Page x:Class="KioskAppWpf.Pages.ServicePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KioskAppWpf.Pages"
      xmlns:kiosk="clr-namespace:KioskAppWpf.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="492" d:DesignWidth="792"
      Title="ErrorPage"
      Unloaded="PageUnload"
      Loaded="Page_Loaded">

    <Grid Background="#FF76CEF0" Margin="0,-1,0,1">
        <StackPanel x:Name="spServiceItems" HorizontalAlignment="Left" Margin="20,20,0,0" Width="350" Height="343" VerticalAlignment="Top"/>
        <StackPanel x:Name="spServiceItemsRight" HorizontalAlignment="Right" Margin="0,20,20,0" Width="368" Height="250" VerticalAlignment="Top"/>

        <Grid Margin="20,0,0,20" Width="350" HorizontalAlignment="Left" VerticalAlignment="Bottom" Height="104">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="21*"/>
                <ColumnDefinition Width="29*"/>
                <ColumnDefinition Width="0*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Margin="30,10,30,0" TextWrapping="Wrap" TextAlignment="left" Text="Licznik wydruku:" VerticalAlignment="Top" FontFamily="Lucida Console" Foreground="#FF0378A4" FontSize="16                        " Height="32" Grid.ColumnSpan="2"/>
            <TextBlock Margin="30,30,0,0" TextWrapping="Wrap" TextAlignment="Left" Text="Aktualna wartość:" VerticalAlignment="Top" FontFamily="Lucida Console" Foreground="#FF0378A4" FontSize="16
                       " Grid.ColumnSpan="2" HorizontalAlignment="Left"/>
            <TextBlock x:Name="tbPrintedNumber" Margin="63,30,0,0" TextWrapping="Wrap" TextAlignment="Left" FontWeight="Bold" Text="" VerticalAlignment="Top" FontFamily="Lucida Console" Foreground="#FF0378A4" FontSize="16
                       " HorizontalAlignment="Left" Grid.Column="1"/>
            <TextBlock Margin="30,50,0,0" TextWrapping="Wrap" TextAlignment="Left" Text="Pozostało ok.:" VerticalAlignment="Top" FontFamily="Lucida Console" Foreground="#FF0378A4" FontSize="16
                       " Grid.ColumnSpan="2" HorizontalAlignment="Left"/>
            <TextBlock x:Name="tbPrintLeft" Margin="63,50,0,0" TextWrapping="Wrap" TextAlignment="Left" FontWeight="Bold" Text="" VerticalAlignment="Top" FontFamily="Lucida Console" Foreground="#FF0378A4" FontSize="16
                       " HorizontalAlignment="Left" Grid.Column="1"/>

            <Grid x:Name="btnReset" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="140" Grid.Column="1">
                <TextBlock Text="R" FontFamily="Lucida Console" Width="30" TextAlignment="Center" FontSize="36" Background="#FF0378A4" VerticalAlignment="Top" HorizontalAlignment="Left" Foreground="#FF13293D" Margin="0,1,0,0" FontWeight="Bold" Height="30"/>
                <TextBlock Text="Resetuj" FontFamily="Lucida Console" FontSize="18" VerticalAlignment="Top" HorizontalAlignment="Left" Foreground="#FF0378A4" Margin="40,7,0,0" FontWeight="Bold" Width="90"/>
            </Grid>
            <Grid x:Name="btnCancel" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="140" Visibility="Hidden" Grid.Column="1">
                <TextBlock Text="N" FontFamily="Lucida Console" Width="30" TextAlignment="Center" FontSize="36" Background="#FF0378A4" VerticalAlignment="Top" HorizontalAlignment="Left" Foreground="#FF13293D" Margin="0,1,0,0" FontWeight="Bold" Height="30"/>
                <TextBlock Text="Anuluj" FontFamily="Lucida Console" FontSize="18" VerticalAlignment="Top" HorizontalAlignment="Left" Foreground="#FF0378A4" Margin="40,7,0,0" FontWeight="Bold" Width="90"/>
            </Grid>
            <Grid x:Name="btnConfirm" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="150" Visibility="Hidden" Margin="0,0,150,0" Grid.ColumnSpan="2">
                <TextBlock Text="T" FontFamily="Lucida Console" Width="30" TextAlignment="Center" FontSize="36" Background="#FF0378A4" VerticalAlignment="Top" HorizontalAlignment="Left" Foreground="#FF13293D" Margin="0,1,0,0" FontWeight="Bold" Height="30"/>
                <TextBlock Text="Potwierdź" FontFamily="Lucida Console" FontSize="18" VerticalAlignment="Top" HorizontalAlignment="Left" Foreground="#FF0378A4" Margin="40,7,0,0" FontWeight="Bold" Width="100
                           "/>
            </Grid>
        </Grid>
        <Grid HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="380" Height="147" Margin="0,0,20,70">
            <TextBlock Margin="10,10,30,0" TextWrapping="Wrap" TextAlignment="Left" Text="Numer karty:" VerticalAlignment="Top" FontFamily="Lucida Console" Foreground="#FF0378A4" FontSize="16
                       " Grid.ColumnSpan="2" HorizontalAlignment="Left"/>
            <TextBlock x:Name="bCardNumber" Margin="160,10,0,0" TextWrapping="Wrap" TextAlignment="Left" FontWeight="Bold" Text="" VerticalAlignment="Top" FontFamily="Lucida Console" Foreground="#FF0378A4" FontSize="16
                       " Grid.ColumnSpan="2" HorizontalAlignment="Left"/>

            <TextBlock Margin="10,30,30,0" TextWrapping="Wrap" TextAlignment="Left" Text="Lokalizacja:" VerticalAlignment="Top" FontFamily="Lucida Console" Foreground="#FF0378A4" FontSize="16
                       " Grid.ColumnSpan="2" HorizontalAlignment="Left"/>
            <TextBlock x:Name="bReaderLocation" Margin="160,30,0,0" TextWrapping="Wrap" TextAlignment="Left" FontWeight="Bold" Text="" VerticalAlignment="Top" FontFamily="Lucida Console" Foreground="#FF0378A4" FontSize="16
                       " Grid.ColumnSpan="2" HorizontalAlignment="Left"/>

            <TextBlock Margin="10,50,30,0" TextWrapping="Wrap" TextAlignment="Left" Text="Typ karty:" VerticalAlignment="Top" FontFamily="Lucida Console" Foreground="#FF0378A4" FontSize="16
                       " Grid.ColumnSpan="2" HorizontalAlignment="Left"/>
            <TextBlock x:Name="bCardType" Margin="160,50,0,0" TextWrapping="Wrap" TextAlignment="Left" FontWeight="Bold" Text="" VerticalAlignment="Top" FontFamily="Lucida Console" Foreground="#FF0378A4" FontSize="16
                       " Grid.ColumnSpan="2" HorizontalAlignment="Left"/>

            <TextBlock Margin="10,70,30,0" TextWrapping="Wrap" TextAlignment="Left" Text="Klient nazwa:" VerticalAlignment="Top" FontFamily="Lucida Console" Foreground="#FF0378A4" FontSize="16
                       " Grid.ColumnSpan="2" HorizontalAlignment="Left"/>
            <TextBlock x:Name="bCustomerName" Margin="160,70,0,0" TextWrapping="Wrap" TextAlignment="Left" FontWeight="Bold" Text="" VerticalAlignment="Top" FontFamily="Lucida Console" Foreground="#FF0378A4" FontSize="16
                       " Grid.ColumnSpan="2" HorizontalAlignment="Left"/>

            <TextBlock Margin="10,90,30,0" TextWrapping="Wrap" TextAlignment="Left" Text="Klient addr1:" VerticalAlignment="Top" FontFamily="Lucida Console" Foreground="#FF0378A4" FontSize="16
                       " Grid.ColumnSpan="2" HorizontalAlignment="Left"/>
            <TextBlock x:Name="bCustomerAddr1" Margin="160,90,0,0" TextWrapping="Wrap" TextAlignment="Left" FontWeight="Bold" Text="" VerticalAlignment="Top" FontFamily="Lucida Console" Foreground="#FF0378A4" FontSize="16
                       " Grid.ColumnSpan="2" HorizontalAlignment="Left"/>

            <TextBlock Margin="10,110,30,0" TextWrapping="Wrap" TextAlignment="Left" Text="Klient addr2:" VerticalAlignment="Top" FontFamily="Lucida Console" Foreground="#FF0378A4" FontSize="16
                       " Grid.ColumnSpan="2" HorizontalAlignment="Left"/>
            <TextBlock x:Name="bCustomerAddr2" Margin="160,110,0,0" TextWrapping="Wrap" TextAlignment="Left" FontWeight="Bold" Text="" VerticalAlignment="Top" FontFamily="Lucida Console" Foreground="#FF0378A4" FontSize="16
                       " Grid.ColumnSpan="2" HorizontalAlignment="Left"/>

            <TextBlock Margin="10,130,30,0" TextWrapping="Wrap" TextAlignment="Left" Text="Klient miasto:" VerticalAlignment="Top" FontFamily="Lucida Console" Foreground="#FF0378A4" FontSize="16
                       " Grid.ColumnSpan="2" HorizontalAlignment="Left"/>
            <TextBlock x:Name="bCustomerCity" Margin="160,130,0,0" TextWrapping="Wrap" TextAlignment="Left" FontWeight="Bold" Text="" VerticalAlignment="Top" FontFamily="Lucida Console" Foreground="#FF0378A4" FontSize="16
                       " Grid.ColumnSpan="2" HorizontalAlignment="Left"/>
        </Grid>

        <Grid HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="380" Height="30" Margin="0,0,20,20">
            <TextBlock Margin="10,10,30,0" TextWrapping="Wrap" TextAlignment="Left" Text="Transakcja:" VerticalAlignment="Top" FontFamily="Lucida Console" Foreground="#FF0378A4" FontSize="16
                       " Grid.ColumnSpan="2" HorizontalAlignment="Left"/>
            <TextBlock x:Name="tbTransaction" Margin="160,10,0,0" Width="210" TextWrapping="Wrap" TextAlignment="Left" FontWeight="Bold" Text="" VerticalAlignment="Top" FontFamily="Lucida Console" Foreground="#FF0378A4" FontSize="10" Grid.ColumnSpan="2" HorizontalAlignment="Left"/>
        </Grid>

        <Grid Background="LightBlue" x:Name="gPassword" Visibility="Hidden">
            <PasswordBox Name="pbPassword" Margin="0"  FontSize="45" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Width="300" Height="50"></PasswordBox>
            <TextBlock Name="tbBadPassword" Text="Błędne hasło" FontSize="24" Foreground="#FFCD0707" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,80,0,0" Visibility="Hidden"></TextBlock>
            <TextBlock Name="tbConfErr" Text="Błąd konfiguracji" FontSize="24" Foreground="#FFCD0707" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,80,0,0" Visibility="Hidden"></TextBlock>
        </Grid>
    </Grid>
</Page>
