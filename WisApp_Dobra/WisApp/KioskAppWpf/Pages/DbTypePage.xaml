<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:Controls="clr-namespace:KioskAppWpf.Controls" x:Class="KioskAppWpf.Pages.DbTypePage" 
      mc:Ignorable="d" 
      d:DesignHeight="492" d:DesignWidth="792"
      Title="SummaryPage" Background="#FF76CEF0"
      Loaded="PageLoad"
      Unloaded="PageUnload">

    <Grid>
        <TextBlock Text="Podaj rodzaj czynności:" Margin="30,60,30,0" Style="{StaticResource ResourceKey=TextPageHead}"/>

        <Grid Width="420" Height="36" VerticalAlignment="Top" Margin="0,110,0,0">
            <Label Content="Naciśnij" Style="{StaticResource ResourceKey=LabelButton}" />
            <TextBlock Text="1" Margin="95,0,0,0" Width="40" Style="{StaticResource ResourceKey=TextBlockButton}" />
            <TextBlock Text=" - Baza stałych klientów" Margin="140,8,0,0" Style="{StaticResource ResourceKey=TextMain}"/>
        </Grid>
        <Grid Width="420" Height="36" VerticalAlignment="Top" Margin="0,170,0,0">
            <Label Content="Naciśnij" Style="{StaticResource ResourceKey=LabelButton}" />
            <TextBlock Text="2" Width="40" Margin="95,0,0,0" Style="{StaticResource ResourceKey=TextBlockButton}"/>
            <TextBlock Text=" - Baza adresów Teryt" Margin="140,8,0,0" Style="{StaticResource ResourceKey=TextMain}"/>
        </Grid>
        
        <Controls:PageFooter x:Name="pfCustomer" Margin="0" VerticalAlignment="Bottom"/>
    </Grid>
</Page>
