      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KioskAppWpf.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="492" d:DesignWidth="792"
      Title="ErrorPage">

    <Grid Background="#FF76CEF0" Margin="0,-1,0,1">
        <TextBlock Margin="0,-70,0,0" Text="Brak koncesji na tą stację zlewną !" Style="{StaticResource ResourceKey=TextErrorHead}" />
        <TextBlock Margin="0,0,0,0" Text="Skontatkuj się z obsługą obiektu" Style="{StaticResource ResourceKey=TextError}"/>

    </Grid>
</Page>
