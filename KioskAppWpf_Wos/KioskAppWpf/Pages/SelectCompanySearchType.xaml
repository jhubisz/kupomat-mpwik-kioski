<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:Controls="clr-namespace:KioskAppWpf.Controls" x:Class="KioskAppWpf.Pages.SelectCompanySearchType" 
      mc:Ignorable="d" 
      d:DesignHeight="492" d:DesignWidth="792"
      Title="SummaryPage" Background="#FF76CEF0"
      Loaded="PageLoaded"
      Unloaded="PageUnload">

    <Grid>
        <Controls:PageHeader x:Name="phHead" Margin="30,40,30,0" VerticalAlignment="Top"/>

        <Grid Width="550" Height="36" VerticalAlignment="Top" Margin="0,110,0,0">
            <Label Content="Naciśnij " Margin="10,0,0,0" Style="{StaticResource ResourceKey=LabelButton}" />
            <TextBlock Text="1" FontFamily="Lucida Console" Width="40" TextAlignment="Center" FontSize="36" Background="#FF13293D" VerticalAlignment="Top" HorizontalAlignment="Left" Foreground="#FF95C3E3" Margin="120,0,0,0" FontWeight="Bold"/>
            <TextBlock Text=" - Wyszukiwanie wytwórcy po nazwie" Margin="160,8,0,0" Style="{StaticResource ResourceKey=TextMain}"/>
        </Grid>
        <Grid Width="550" Height="36" VerticalAlignment="Top" Margin="0,170,0,0">
            <Label Content="Naciśnij " Margin="10,0,0,0" Style="{StaticResource ResourceKey=LabelButton}" />
            <TextBlock Text="2" FontFamily="Lucida Console" Width="40" TextAlignment="Center" FontSize="36" Background="#FF13293D" VerticalAlignment="Top" HorizontalAlignment="Left" Foreground="#FF95C3E3" Margin="120,0,0,0" FontWeight="Bold"/>
            <TextBlock Text=" - Wyszukiwanie wytwórcy po adresie" Margin="160,8,0,0" Style="{StaticResource ResourceKey=TextMain}"/>
        </Grid>
        
        <Controls:PageFooter x:Name="pfCustomer" Margin="0" VerticalAlignment="Bottom"/>
    </Grid>
</Page>
