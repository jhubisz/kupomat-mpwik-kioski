<Page x:Class="KioskAppWpf.Pages.Errors.DeviceFlowErrorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KioskAppWpf.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="492" d:DesignWidth="792"
      Title="ErrorPage">

    <Grid Background="#FF76CEF0" Margin="0,-1,0,1">
        <TextBlock Margin="0,190,0,270" Foreground="#FFD10C13" FontSize="24" Text="Awaria urządzenia!" Style="{StaticResource ResourceKey=TextPageHead}"/>
        <TextBlock Margin="0,230,0,0" Text="Skontatkuj się z obsługą obiektu" Foreground="#FFD10C13"  Style="{StaticResource ResourceKey=TextPageHead}"/>
        <TextBlock Margin="0,260,0,0" Name="tbTakeRecipt" Text="Odbierz potwierdzenie przyjęcia dostawy" Visibility="Hidden" TextDecorations="Underline" Foreground="#FFD10C13" FontWeight="Bold" Style="{StaticResource ResourceKey=TextPageHead}"/>
        <TextBlock Margin="0,260,0,0" Name="tbPrintingBlocked" Text="Drukowanie paragonu zablokowane" Visibility="Hidden" TextDecorations="Underline" Foreground="#FFD10C13" FontWeight="Bold" Style="{StaticResource ResourceKey=TextPageHead}"/>
        <TextBlock Margin="0,290,0,0" Name="tbErrorCode" Text="" Foreground="#FFD10C13" Style="{StaticResource ResourceKey=TextPageHead}"/>
    </Grid>
</Page>
