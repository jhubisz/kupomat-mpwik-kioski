<UserControl x:Class="KioskAppWpf.Controls.CargoTypeItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KioskAppWpf.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="38" d:DesignWidth="792">
    <Grid>
        <Label Content="Naciśnij" Margin="134,1,0,0" Style="{StaticResource ResourceKey=LabelButton}"/>
        <TextBlock x:Name="tbKey" Text="{Binding Path=ShortcutKey}" Width="40" VerticalAlignment="Center" Style="{StaticResource ResourceKey=TextBlockButton}" Margin="230,1,0,0" />
        <TextBlock x:Name="tbDash" Text="-" VerticalAlignment="Center" Margin="290,0,0,0" Style="{StaticResource ResourceKey=TextMain}"/>
        <TextBlock x:Name="tbName" Text="{Binding Path=CargoTypeLabel}" VerticalAlignment="Center" Margin="310,0,0,0" Style="{StaticResource ResourceKey=TextMain}"/>
    </Grid>
</UserControl>
